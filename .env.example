# Cybersecurity Nexus configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus_password

# Optional: GitHub Personal Access Token for higher rate limits on GHSA ingestion
# Create at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# Optional: NVD API key (https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=

# API host
API_HOST=127.0.0.1
API_PORT=8000
